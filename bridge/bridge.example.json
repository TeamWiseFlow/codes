{
  "projects": {
    "myapp": {
      "path": "/home/user/projects/myapp",
      "feishu": {
        "appId": "cli_xxx",
        "appSecretPath": "~/.codes/secrets/myapp_secret"
      }
    },
    "backend": {
      "path": "/home/user/projects/backend",
      "feishu": {
        "appId": "cli_yyy",
        "appSecretPath": "~/.codes/secrets/backend_secret"
      }
    },
    "atomcode-project": {
      "path": "/home/user/projects/atomcode-project",
      "feishu": {
        "appId": "cli_zzz",
        "appSecretPath": "~/.codes/secrets/atomcode_secret"
      },
      "backend": "atomcode",
      "atomcode": {
        "daemonBin": "atomcode-daemon",
        "approvalMode": "bypass",
        "port": 13456,
        "model": "AtomGit-GLM-5.2"
      }
    }
  },
  "thinkingThresholdMs": 2500,
  "claudePath": "claude",
  "debug": false,
  "backup": {
    "time": "04:16",
    "dest": "~/Backups"
  }
}
